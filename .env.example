# Copy this file to .env.local (locally) and also add each value in
# Netlify -> Site configuration -> Environment variables when you deploy.

# --- Google service account (used for BOTH the Sheets database AND Calendar sync) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- Google Sheet acting as the database ---
GOOGLE_SHEET_ID=

# --- Google Calendar sync (optional but recommended) ---
GOOGLE_CALENDAR_ID=

# --- Email notifications (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@yourdomain.com

# --- Admin dashboard password (make this up yourself, any string) ---
ADMIN_DASHBOARD_KEY=
